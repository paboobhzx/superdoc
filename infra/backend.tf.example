# Remote state example (S3 backend).
#
# This repo’s recommended entrypoints are `infra/environments/{dev,stage,prod}`.
# If you want to run Terraform from `infra/` directly, copy this file to
# `infra/backend.tf` and set the bucket name (or pass `-backend-config`).
#
# Backend bucket must exist before `terraform init`.
# See `infra/bootstrap_backend/` for a tiny bootstrap Terraform that creates it.

terraform {
  backend "s3" {
    # Fill in values via -backend-config flags or backend.hcl (never commit real values)
    bucket         = "superdoc-tfstate"
    key            = "superdoc/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    # DynamoDB table locking is deprecated. Prefer S3-native locking.
    use_lockfile = true
  }
}
